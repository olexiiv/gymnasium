<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} — {{ site.shortName }}{% else %}{{ site.name }}{% endif %}</title>
  <meta name="description" content="{{ description or (site.name + ' — офіційний сайт закладу освіти. Вступ, розклад, новини, документи, контакти.') }}">
  <link rel="canonical" href="{{ page.url | absoluteUrl(site.url) }}">
  <meta property="og:title" content="{{ title or site.name }}">
  <meta property="og:description" content="{{ description or site.tagline }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ page.url | absoluteUrl(site.url) }}">
  <meta property="og:image" content="{{ '/assets/img/emblema.png' | absoluteUrl(site.url) }}">
  <link rel="icon" type="image/png" href="/assets/img/favicon.png">
  <link rel="apple-touch-icon" href="/assets/img/emblema-320.png">

  {# Запобігання FOUC: клас версії для слабозорих застосовується до першого рендеру #}
  <script>
    (function () {
      try {
        if (localStorage.getItem("a11y-mode") === "on") {
          document.documentElement.classList.add("a11y");
        }
      } catch (e) {}
    })();
  </script>

  <link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>
  <a class="skip-link" href="#main">До основного вмісту</a>

  {% include "partials/header.njk" %}

  <main id="main">
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}

  <script src="/assets/js/main.js" defer></script>
</body>
</html>
