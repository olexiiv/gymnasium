{# Використання: {% icon "calendar" %} або {% icon "calendar", 20 %} #}
{% macro icon(name, size=24, class="") %}<svg class="icon{% if class %} {{ class }}{% endif %}" width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">{% include "icons/" + name + ".svg" %}</svg>{% endmacro %}
