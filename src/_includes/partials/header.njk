{% from "macros/icon.njk" import icon %}
<header class="header" id="header">
  <div class="header__inner container">
    <a class="header__brand" href="/" aria-label="{{ site.name }} — на головну">
      <img class="header__logo" src="/assets/img/emblema-320.png" alt="" width="48" height="48">
      <span class="header__name">{{ site.shortName }}</span>
    </a>

    <nav class="header__nav" id="site-nav" aria-label="Основна навігація">
      <ul class="header__list">
        {% for item in site.nav %}
        <li>
          <a class="header__link{% if page.url and item.url != '/' and page.url.startsWith(item.url) %} is-active{% endif %}"
             {% if page.url and item.url != '/' and page.url.startsWith(item.url) %}aria-current="page"{% endif %}
             href="{{ item.url }}">{{ item.label }}</a>
        </li>
        {% endfor %}
        <li class="header__cta-item">
          <a class="btn btn--brand btn--sm" href="/rozklad/">{{ icon("calendar", 18) }} Розклад</a>
        </li>
      </ul>
    </nav>

    <div class="header__actions">
      <a class="header__iconbtn tip" href="{{ site.oldSiteUrl }}" rel="noopener"
         data-tip="Стара версія сайту" aria-label="Стара версія сайту">
        {{ icon("external-link", 20) }}
      </a>
      <button class="header__iconbtn header__a11y tip" id="a11y-toggle" type="button"
              aria-pressed="false" data-tip="Для слабозорих" aria-label="Версія для слабозорих">
        {{ icon("eye", 20) }}
      </button>
      <button class="header__burger" id="nav-toggle" type="button"
              aria-expanded="false" aria-controls="site-nav" aria-label="Відкрити меню">
        <span class="header__burger-open">{{ icon("menu", 24) }}</span>
        <span class="header__burger-close">{{ icon("x", 24) }}</span>
      </button>
    </div>
  </div>
</header>
