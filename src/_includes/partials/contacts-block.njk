{% from "macros/icon.njk" import icon %}
<div class="contacts">
  <div class="contacts__info">
    <div class="contacts__note" role="note">
      {{ icon("shield", 22) }}
      <p>Заклад релоковано із {{ site.address.origin }}, {{ site.address.region }}. Навчання відбувається дистанційно, тож найшвидше звʼязатися з нами електронною поштою або через форму поруч.</p>
    </div>

    <dl class="contacts__official">
      <div class="contacts__row">
        <dt>{{ icon("landmark", 18) }} Повна назва</dt>
        <dd>{{ site.fullName }}</dd>
      </div>
      <div class="contacts__row">
        <dt>{{ icon("book-open", 18) }} Тип закладу</dt>
        <dd>{{ site.type }}</dd>
      </div>
      <div class="contacts__row">
        <dt>{{ icon("users", 18) }} Директор</dt>
        <dd>{{ site.director }}</dd>
      </div>
      <div class="contacts__row">
        <dt>{{ icon("map-pin", 18) }} Поштова адреса</dt>
        <dd>{{ site.address.postal }}</dd>
      </div>
      <div class="contacts__row">
        <dt>{{ icon("phone", 18) }} Телефон</dt>
        <dd><a href="tel:{{ site.phoneHref }}">{{ site.phone }}</a></dd>
      </div>
      <div class="contacts__row">
        <dt>{{ icon("mail", 18) }} E-mail</dt>
        <dd><a href="mailto:{{ site.email }}">{{ site.email }}</a></dd>
      </div>
      <div class="contacts__row">
        <dt>{{ icon("clock", 18) }} Графік роботи</dt>
        <dd>{{ site.hours }}</dd>
      </div>
      <div class="contacts__row">
        <dt>{{ icon("file-text", 18) }} Засновник</dt>
        <dd>{{ site.founder }}</dd>
      </div>
      <div class="contacts__row">
        <dt>{{ icon("file-text", 18) }} Код ЄДРПОУ</dt>
        <dd>{{ site.edrpou }}</dd>
      </div>
    </dl>
  </div>

  <form class="form" action="https://formspree.io/f/{{ site.formspreeId }}" method="POST" novalidate>
    <h3 class="form__title">Напишіть нам</h3>
    <p class="form__note">Відповідаємо протягом одного робочого дня.</p>

    <div class="form__field">
      <label for="cf-name">Ваше імʼя</label>
      <input id="cf-name" name="name" type="text" autocomplete="name" required
             aria-describedby="cf-name-err">
      <p class="form__error" id="cf-name-err" hidden>Вкажіть, будь ласка, ваше імʼя.</p>
    </div>

    <div class="form__field">
      <label for="cf-email">Електронна пошта</label>
      <input id="cf-email" name="_replyto" type="email" autocomplete="email" required
             aria-describedby="cf-email-err">
      <p class="form__error" id="cf-email-err" hidden>Перевірте адресу пошти — вона виглядає неповною.</p>
    </div>

    <div class="form__field">
      <label for="cf-message">Повідомлення</label>
      <textarea id="cf-message" name="message" rows="5" required
                aria-describedby="cf-message-err"></textarea>
      <p class="form__error" id="cf-message-err" hidden>Напишіть кілька слів — з чим можемо допомогти?</p>
    </div>

    <div class="form__hp" aria-hidden="true">
      <label for="cf-website">Не заповнюйте це поле</label>
      <input id="cf-website" name="_gotcha" type="text" tabindex="-1" autocomplete="off">
    </div>

    <input type="hidden" name="_subject" value="Повідомлення з сайту гімназії">

    <button class="btn btn--brand" type="submit">Надіслати {{ icon("arrow-right", 18) }}</button>
    <p class="form__status" data-form-status role="status" aria-live="polite"></p>
  </form>
</div>
