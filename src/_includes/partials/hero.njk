{% from "macros/icon.njk" import icon %}
<section class="hero" aria-labelledby="hero-title">
  <div class="hero__leaves" aria-hidden="true">
    <span class="hero__leaf hero__leaf--1">{{ icon("leaf", 42) }}</span>
    <span class="hero__leaf hero__leaf--2">{{ icon("leaf", 28) }}</span>
    <span class="hero__leaf hero__leaf--3">{{ icon("leaf", 34) }}</span>
  </div>
  <div class="container hero__inner">
    <div class="hero__text">
      <p class="hero__eyebrow">{{ site.address.region }} · дистанційне навчання</p>
      <h1 class="hero__title" id="hero-title">Продовжуємо навчати —<br><em>попри все.</em></h1>
      <p class="hero__lead">Андріївська гімназія релокована з Бердянського району й нині працює дистанційно. {{ site.metrics[0].value }} учнів з різних куточків України та з тимчасово окупованих територій навчаються, спілкуються й отримують підтримку — разом, попри відстань.</p>
      <div class="hero__actions">
        <a class="btn btn--brand btn--lg" href="/vstup/">Як до нас вступити {{ icon("arrow-right", 20) }}</a>
        <a class="btn btn--ghost btn--lg" href="/pro-gimnaziyu/">Про нас</a>
      </div>
    </div>
    <div class="hero__media">
      <figure class="hero__photo">
        <picture>
          <source type="image/webp" srcset="/assets/img/school-480.webp 480w, /assets/img/school.webp 960w"
                  sizes="(min-width: 900px) 30rem, 92vw">
          <img src="/assets/img/school.jpg" width="960" height="640" fetchpriority="high"
               alt="Головний корпус Андріївської гімназії: двоповерхова будівля з розмальованим у кольори веселки ґанком і державним прапором">
        </picture>
      </figure>
    </div>
  </div>
</section>
